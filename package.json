{
  "name": "wyatts-notes",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --build --port 3000",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write --loglevel=warn --ignore-path .prettierignore './**/*.{js,ts,json,md,html,css,scss,yml,yaml}'",
    "precommit": "npm run lint && npm run format",
    "prepare": "husky",
    "spellcheck": "cspell \"docs/**/*.md\" \"docs/**/*.mdx\" \"src/**/*.md\" \"src/**/*.mdx\"",
    "mdlint": "markdownlint \"docs/**/*.md\" \"docs/**/*.mdx\"",
    "content-check": "npm run mdlint && npm run spellcheck"
  },
  "dependencies": {
    "@adobe/remark-gridtables": "^3.0.20",
    "@algolia/autocomplete-js": "^1.19.8",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/plugin-sitemap": "^3.9.2",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-live-codeblock": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@fontsource/inter": "^5.2.6",
    "@fontsource/jetbrains-mono": "^5.2.6",
    "@fontsource/merriweather": "^5.2.9",
    "@mdx-js/react": "^3.1.0",
    "@r74tech/docusaurus-plugin-panzoom": "^2.4.0",
    "algoliasearch": "^5.50.2",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "docusaurus-theme-redoc": "^2.5.0",
    "glob": "^13.0.6",
    "katex": "^0.16.44",
    "lunr": "^2.3.9",
    "lunr-languages": "^1.14.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-code-snippets": "^1.1.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@tailwindcss/typography": "^0.5.16",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "cspell": "^9.7.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": "22"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=4.5.4"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ]
  }
}
