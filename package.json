{
  "name": "wyatts-notes",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --build --port 3000",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write --loglevel=warn --ignore-path .prettierignore './**/*.{js,ts,json,md,html,css,scss,yml,yaml}'",
    "precommit": "npm run lint && npm run format",
    "prepare": "husky",
    "spellcheck": "cspell \"docs/**/*.md\" \"docs/**/*.mdx\" \"src/**/*.md\" \"src/**/*.mdx\"",
    "mdlint": "markdownlint \"docs/**/*.md\" \"docs/**/*.mdx\"",
    "content-check": "npm run mdlint && npm run spellcheck",
    "validate:mdx": "python3 scripts/validate-mdx.py",
    "validate:links": "python3 scripts/check-links.py",
    "validate:content": "python3 scripts/validate-mdx.py && python3 scripts/check-links.py",
    "validate:depth": "python3 scripts/check-depth-tiers.py",
    "validate:handwaves": "python3 scripts/check-handwaves.py",
    "validate:descriptions": "python3 scripts/check-descriptions.py",
    "validate:forward-refs": "python3 scripts/check-forward-refs.py",
    "validate:search-index": "python3 scripts/check-search-index-coverage.py",
    "validate:all": "python3 scripts/validate-mdx.py && python3 scripts/check-links.py && python3 scripts/check-depth-tiers.py && python3 scripts/check-handwaves.py && python3 scripts/check-descriptions.py && python3 scripts/check-forward-refs.py && python3 scripts/check-search-index-coverage.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lighthouse": "lhci autorun",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "algolia:index": "node scripts/index-algolia.js"
  },
  "dependencies": {
    "@adobe/remark-gridtables": "^3.0.20",
    "@fontsource/inter": "^5.2.6",
    "@fontsource/jetbrains-mono": "^5.2.6",
    "@fontsource/merriweather": "^5.2.9",
    "@mdx-js/react": "^3.1.0",
    "@mermaid-js/layout-elk": "0.1.9",
    "@r74tech/docusaurus-plugin-panzoom": "^2.4.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "docusaurus-theme-redoc": "^2.5.0",
    "dotenv-flow": "^4.1.0",
    "katex": "^0.16.44",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-code-snippets": "^1.1.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/plugin-sitemap": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-live-codeblock": "^3.10.0",
    "@docusaurus/theme-mermaid": "^3.10.0",
    "@docusaurus/tsconfig": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "algoliasearch": "^5.50.2",
    "cspell": "^9.7.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.5.14",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4",
    "workbox-build": "^7.4.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22 <27",
    "pnpm": ">=10 <11"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=4.5.4",
      "webpackbar": "^7.0.0",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "minimatch": ">=9.0.7",
      "picomatch": ">=4.0.0",
      "node-forge": ">=1.3.2",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7",
      "path-to-regexp": ">=0.1.13",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.2",
      "svgo": ">=3.3.3",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ]
  }
}
