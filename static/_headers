/*
  Security Headers (Cloudflare Pages)
  Applied to all subdomains via static/_headers
*/

# Prevent framing of the site
X-Frame-Options: DENY
# Prevent MIME type sniffing
X-Content-Type-Options: nosniff
# Control referrer information leakage
Referrer-Policy: strict-origin-when-cross-origin
# Block access to device features
Permissions-Policy: camera=(), microphone=(), geolocation=()

# Enforce HTTPS with HSTS (1 year, include subdomains)
Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Content Security Policy
# script-src: no 'unsafe-inline' — Docusaurus only loads local scripts
# style-src: 'unsafe-inline' required for Docusaurus critical CSS injection
# frame-src: Desmos, GeoGebra, PhET simulation iframes
# connect-src: Algolia search, Sentry error reporting, Cloudflare analytics, jsDelivr
Content-Security-Policy: default-src 'self'; script-src 'self' 'https://cdn.jsdelivr.net' 'https://www.googletagmanager.com' 'https://static.cloudflareinsights.com'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' https://algolia.net https://cdn.jsdelivr.net https://cloudflareinsights.com https://sentry.io https://o4510614385852416.ingest.de.sentry.io; frame-src 'self' https://www.google.com https://www.desmos.com https://www.geogebra.org https://phet.colorado.edu; base-uri 'self'; report-uri /csp-report; report-to default
Report-To: {"group":"default","max_age":31536000,"endpoints":[{"url":"/csp-report"}]}

# Cross-origin isolation (Spectre-class protection)
Cross-Origin-Opener-Policy: same-origin
Cross-Origin-Resource-Policy: same-origin
Cross-Origin-Embedder-Policy: require-corp

# Cache-Control: Static assets
/static/img/*
  Cache-Control: public, max-age=31536000, immutable

/static/css/*
  Cache-Control: public, max-age=604800

/static/css/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/static/js/*
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
