/*
  Security Headers (Cloudflare Pages)
  Applied to all subdomains via static/_headers
*/

# Prevent framing of the site
X-Frame-Options: DENY
# Prevent MIME type sniffing
X-Content-Type-Options: nosniff
# Control referrer information leakage
Referrer-Policy: strict-origin-when-cross-origin
# Block access to device features
Permissions-Policy: camera=(), microphone=(), geolocation=()

# Enforce HTTPS with HSTS (1 year, include subdomains)
Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Content Security Policy
Content-Security-Policy: default-src 'self'; script-src 'self' 'https://cdn.jsdelivr.net' 'https://www.googletagmanager.com'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' https://algolia.net https://cdn.jsdelivr.net; frame-src 'self' https://www.google.com; base-uri 'self'

# Cross-origin isolation (Spectre-class protection)
Cross-Origin-Opener-Policy: same-origin
Cross-Origin-Resource-Policy: same-origin
Cross-Origin-Embedder-Policy: require-corp
