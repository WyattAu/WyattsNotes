#!/usr/bin/env sh
# Pre-commit hook: runs all validation checks before allowing a commit.
# Fails the commit if any check exits non-zero.
# Set SKIP_PRECHECK=1 to bypass (emergency use only).

set -e

# --- Environment check ---
NODE_VERSION=$(node -v | sed 's/^v//')
NODE_MAJOR=$(echo "$NODE_VERSION" | cut -d. -f1)
if [ "$NODE_MAJOR" -lt 22 ] || [ "$NODE_MAJOR" -gt 26 ]; then
  echo "[pre-commit] WARNING: Node.js $NODE_VERSION detected. Recommended: 22.x. Some checks may fail."
fi

# --- Fast checks first (lint-staged + typecheck) ---
echo "[pre-commit] Running lint-staged (eslint --fix + prettier --write)..."
npx lint-staged

echo "[pre-commit] Running TypeScript typecheck..."
NODE_OPTIONS="--max-old-space-size=8192" npx tsc --noEmit

# --- Unit tests ---
echo "[pre-commit] Running unit tests (vitest, timeout 120s)..."
timeout 120 npx vitest run --reporter=verbose || {
  echo "[pre-commit] ERROR: Unit tests failed or timed out. Check Node.js version (requires 22, current: $(node -v))."
  exit 1
}

# --- Content validation ---
echo "[pre-commit] Validating MDX content (emojis, admonitions, raw HTML)..."
python3 scripts/validate-mdx.py

echo "[pre-commit] Checking relative links..."
python3 scripts/check-links.py

echo "[pre-commit] Checking content depth tiers (informational)..."
python3 scripts/check-depth-tiers.py || true

echo "[pre-commit] Checking description quality (informational)..."
python3 scripts/check-descriptions.py || true

echo "[pre-commit] Checking forward references (informational)..."
python3 scripts/check-forward-refs.py || true

# --- Informational (non-blocking) ---
echo "[pre-commit] Checking hand-wave phrases (informational)..."
python3 scripts/check-handwaves.py || true

echo "[pre-commit] Checking search index coverage (informational)..."
python3 scripts/check-search-index-coverage.py || true

echo "[pre-commit] All checks passed."
